# BeatStack Library — variáveis de ambiente

DATABASE_URL="file:./prisma/dev.db"

# Obrigatório em produção (VPS e app instalado)
JWT_SECRET="troque-por-uma-chave-longa-e-aleatoria"

# Webhook de cadastro automático (página de vendas / n8n → POST /api/webhooks/register-user)
REGISTRATION_WEBHOOK_SECRET="segredo-compartilhado-com-n8n-ou-automacao"

# VPS — URL pública (referência; no desktop use BEATSTACK_SERVER_URL ou server.json)
# NEXT_PUBLIC_APP_URL="https://library.seudominio.com"

# Apenas desenvolvimento local — desliga login (não use em produção!)
# AUTH_DISABLED=true
