{
  "name": "beatstack-library",
  "version": "0.1.0",
  "private": true,
  "main": "desktop/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:clean": "powershell -ExecutionPolicy Bypass -File scripts/dev-clean.ps1",
    "desktop:clean": "powershell -ExecutionPolicy Bypass -File scripts/desktop-dev.ps1",
    "build": "prisma generate && next build",
    "start": "next start",
    "desktop": "electron desktop/main.js",
    "desktop:dev": "concurrently -k \"npm run dev\" \"wait-on http://127.0.0.1:3000 && electron desktop/main.js\"",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "admin:create": "tsx scripts/create-admin.ts",
    "postinstall": "prisma generate",
    "pack:desktop": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.17",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.21.0",
    "mercadopago": "^3.1.0",
    "music-metadata": "^11.13.0",
    "next": "16.2.9",
    "node-unrar-js": "^2.0.2",
    "prisma": "^5.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "slugify": "^1.6.9",
    "stripe": "^22.2.2",
    "tailwind-merge": "^3.6.0",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^8.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "concurrently": "^9.2.1",
    "electron": "^35.7.5",
    "wait-on": "^8.0.5",
    "electron-builder": "^25.1.8",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "build": {
    "appId": "com.beatstack.library",
    "productName": "BeatStack Library",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "desktop/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": ["**/*"]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": "standalone/public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": ["nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "shortcutName": "BeatStack Library"
    }
  }
}
